{
  "name": "mcp-bridge-figma",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:plugin": "node esbuild.plugin.mjs",
    "build:mcp": "node esbuild.mcp.mjs",
    "bridge": "tsx src/bridge/server.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:dist": "node dist-mcp/server.js",
    "print-mcp-config": "node scripts/print-mcp-config.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:plugin": "tsc -p tsconfig.plugin.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.114.0",
    "@types/node": "^24.12.2",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^3.0.0"
  }
}
